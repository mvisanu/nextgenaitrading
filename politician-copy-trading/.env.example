# Copy this to .env and fill in your values
# These should match what's in backend/.env

visanu_alpaca_endpoint_url=https://paper-api.alpaca.markets
visanu_alpaca_api_key=your_api_key_here
visanu_alpaca_secret_key=your_secret_key_here

# --- Bot settings ---
# Dollar amount per copied trade (default $300)
COPY_TRADE_AMOUNT=300

# Dry run = True means no real orders placed, just logged
DRY_RUN=true

# Politician slug to follow. Leave blank to auto-select best performer.
# Example: nancy-pelosi, michael-burgess
TARGET_POLITICIAN=

# How many days back to analyze for ranking
RANK_LOOKBACK_DAYS=90

# Minimum trades in lookback window to qualify for ranking
MIN_TRADES_TO_QUALIFY=5

# Scheduler: how often to check for new trades (minutes, during market hours)
POLL_INTERVAL_MIN=15

# Scheduler: how often to re-rank politicians (hours)
RERANK_INTERVAL_HOURS=24

# Optional: path to SQLite DB for trade tracking
DB_PATH=./trade_history.db
