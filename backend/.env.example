# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nextgen:nextgen@localhost:5432/nextgenstock

# ── JWT (legacy — kept for token signing fallback) ────────────────────────────
SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Supabase Auth (required) ─────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Fernet encryption (broker credentials) ───────────────────────────────────
ENCRYPTION_KEY=change-me-generate-with-python-cryptography-fernet

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Cookies ──────────────────────────────────────────────────────────────────
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ── Debug ────────────────────────────────────────────────────────────────────
DEBUG=true

# ── Broker URLs ──────────────────────────────────────────────────────────────
ALPACA_BASE_URL=https://api.alpaca.markets
ALPACA_PAPER_URL=https://paper-api.alpaca.markets
