# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg driver required; format: postgresql+asyncpg://user:pass@host/dbname
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/nextgenstock

# ── JWT Auth ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-strong-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Credential Encryption ─────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ── Cookie settings ───────────────────────────────────────────────────────────
# Set COOKIE_SECURE=true in production (requires HTTPS)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ── Connection pool (optional overrides) ──────────────────────────────────────
POOL_SIZE=5
MAX_OVERFLOW=10

# ── Alpaca (default broker — stocks/ETFs) ─────────────────────────────────────
ALPACA_BASE_URL=https://api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_PAPER_URL=https://paper-api.alpaca.markets

# ── Robinhood (crypto only — optional) ────────────────────────────────────────
ROBINHOOD_BASE_URL=https://trading.robinhood.com
